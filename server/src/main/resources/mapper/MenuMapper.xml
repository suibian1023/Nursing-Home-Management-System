<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.yyzx.mapper.MenuMapper">

    <resultMap id="BaseResultMap" type="com.neuedu.yyzx.pojo.Menu">
        <id column="id" property="id"/>
        <result column="menus_index" property="menusIndex"/>
        <result column="title" property="title"/>
        <result column="icon" property="icon"/>
        <result column="path" property="path"/>
        <result column="parent_id" property="parentId"/>
        <result column="create_time" property="createTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectMenuByRoleId" resultMap="BaseResultMap">
        SELECT DISTINCT m.id, m.menus_index, m.title, m.icon, m.path, m.parent_id,
                        m.create_time, m.is_deleted
        FROM menu m
        INNER JOIN rolemenu rm ON m.id = rm.menu_id
        WHERE rm.role_id = #{roleId}
          AND m.is_deleted = 0
          AND rm.is_deleted = 0
        ORDER BY m.id
    </select>

</mapper>
