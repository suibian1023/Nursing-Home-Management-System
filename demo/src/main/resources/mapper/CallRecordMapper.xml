<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.yyzx.mapper.CallRecordMapper">

    <resultMap id="BaseResultMap" type="com.neuedu.yyzx.pojo.CallRecord">
        <id column="id" property="id"/>
        <result column="customer_id" property="customerId"/>
        <result column="room_no" property="roomNo"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="customer_name" property="customerName"/>
    </resultMap>

    <select id="selectCallPage" resultMap="BaseResultMap">
        SELECT cr.*, c.customer_name
        FROM call_record cr
        LEFT JOIN customer c ON cr.customer_id = c.id AND c.is_deleted = 0
        WHERE cr.is_deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (c.customer_name LIKE CONCAT('%', #{keyword}, '%')
                 OR cr.room_no LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY cr.status ASC, cr.create_time DESC
    </select>

</mapper>
