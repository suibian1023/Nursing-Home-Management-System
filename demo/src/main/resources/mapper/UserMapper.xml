<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.yyzx.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.neuedu.yyzx.pojo.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="email" property="email"/>
        <result column="phone_number" property="phoneNumber"/>
        <result column="sex" property="sex"/>
        <result column="role_id" property="roleId"/>
        <result column="avatar" property="avatar"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <resultMap id="VoResultMap" type="com.neuedu.yyzx.vo.UserVo" extends="BaseResultMap">
        <result column="role_name" property="roleName"/>
        <result column="create_time_str" property="createTimeStr"/>
    </resultMap>

    <sql id="Base_Column_List">
        u.id, u.username, u.password, u.nickname, u.email, u.phone_number,
        u.sex, u.role_id, u.avatar, u.create_by, u.create_time, u.is_deleted
    </sql>

    <select id="selectPageVo" resultMap="VoResultMap">
        SELECT
            <include refid="Base_Column_List"/>,
            r.role_name AS role_name,
            DATE_FORMAT(u.create_time, '%Y-%m-%d %H:%i:%s') AS create_time_str
        FROM user u
        LEFT JOIN role r ON u.role_id = r.id
        <where>
            u.is_deleted = 0
            <if test="username != null and username != ''">
                AND u.username LIKE CONCAT('%', #{username}, '%')
            </if>
        </where>
        ORDER BY u.create_time DESC
    </select>

</mapper>
