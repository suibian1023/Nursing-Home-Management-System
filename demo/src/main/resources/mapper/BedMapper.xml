<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.yyzx.mapper.BedMapper">

    <select id="selectBedCount" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM bed
        WHERE room_no = #{roomNo}
          AND is_deleted = 0
    </select>

</mapper>
