<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.yyzx.mapper.CustomerMapper">

    <resultMap id="BaseResultMap" type="com.neuedu.yyzx.pojo.Customer">
        <id column="id" property="id"/>
        <result column="customer_name" property="customerName"/>
        <result column="customer_sex" property="customerSex"/>
        <result column="customer_age" property="customerAge"/>
        <result column="id_card" property="idCard"/>
        <result column="phone" property="phone"/>
        <result column="address" property="address"/>
        <result column="checkin_date" property="checkinDate"/>
        <result column="room_no" property="roomNo"/>
        <result column="bed_id" property="bedId"/>
        <result column="nurse_level_id" property="nurseLevelId"/>
        <result column="user_id" property="userId"/>
        <result column="create_time" property="createTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <resultMap id="VoResultMap" type="com.neuedu.yyzx.vo.CustomerVo" extends="BaseResultMap">
        <result column="nurse_level_name" property="nurseLevelName"/>
        <result column="user_name" property="userName"/>
        <result column="bed_no" property="bedNo"/>
        <result column="customer_sex_str" property="customerSexStr"/>
        <result column="checkin_date_str" property="checkinDateStr"/>
        <result column="create_time_str" property="createTimeStr"/>
    </resultMap>

    <sql id="Base_Column_List">
        c.id, c.customer_name, c.customer_sex, c.customer_age, c.id_card,
        c.phone, c.address, c.checkin_date, c.room_no, c.bed_id,
        c.nurse_level_id, c.user_id, c.create_time, c.is_deleted
    </sql>

    <select id="selectPageVo" resultMap="VoResultMap">
        SELECT
            <include refid="Base_Column_List"/>,
            nl.level_name AS nurse_level_name,
            u.nickname AS user_name,
            b.bed_no AS bed_no,
            CASE WHEN c.customer_sex = 1 THEN '女' ELSE '男' END AS customer_sex_str,
            DATE_FORMAT(c.checkin_date, '%Y-%m-%d') AS checkin_date_str,
            DATE_FORMAT(c.create_time, '%Y-%m-%d %H:%i:%s') AS create_time_str
        FROM customer c
        LEFT JOIN nurselevel nl ON c.nurse_level_id = nl.id AND nl.is_deleted = 0
        LEFT JOIN user u ON c.user_id = u.id AND u.is_deleted = 0
        LEFT JOIN bed b ON c.bed_id = b.id AND b.is_deleted = 0
        <where>
            c.is_deleted = 0
            <if test="customerName != null and customerName != ''">
                AND c.customer_name LIKE CONCAT('%', #{customerName}, '%')
            </if>
        </where>
        ORDER BY c.create_time DESC
    </select>

</mapper>
